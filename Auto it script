; 11. Text Repeater
; Question: Create a script that asks the user for a phrase and a number, then repeatedly types the phrase that many times into any open application.
; Priyanshi Siddhapura/AB
#include <GUIConstantsEx.au3>

$hGUI = GUICreate("Text Repeater", 400, 180)
$inputText = GUICtrlCreateInput("", 80, 30, 200, 20)
$inputCount = GUICtrlCreateInput("", 80, 60, 200, 20)
GUICtrlCreateLabel("Text:", 10, 32, 50, 20)
GUICtrlCreateLabel("Count:", 10, 62, 50, 20)
$btnRepeat = GUICtrlCreateButton("Start Repeating", 80, 100, 100, 30)
$btnStop = GUICtrlCreateButton("Stop", 190, 100, 100, 30)
GUISetState(@SW_SHOW)

Global $bRepeat = False

While 1
    $nMsg = GUIGetMsg()
    Switch $nMsg
        Case $GUI_EVENT_CLOSE
            Exit
        Case $btnRepeat
            $sText = GUICtrlRead($inputText)
            $iCount = Int(GUICtrlRead($inputCount))
            If $sText <> "" And $iCount > 0 Then
                $bRepeat = True
                StartRepeating($sText, $iCount)
            EndIf
        Case $btnStop
            $bRepeat = False
    EndSwitch
WEnd

Func StartRepeating($sText, $iCount)
    Sleep(3000) ; 3 second delay to switch to target application
    For $i = 1 To $iCount
        If Not $bRepeat Then ExitLoop
        Send($sText & "{ENTER}")
        Sleep(100)
    Next
EndFunc

