; 1. Custom Hotkey Actions
; Question: Write a script that assigns custom actions to specific hotkeys.
; For example: Ctrl + Alt + N opens Notepad, Ctrl + Alt + B opens a specific folder, Ctrl + Alt + E exits the script.
; Mohit Lalwani/AB
HotKeySet("^!n", "OpenNotepad")
HotKeySet("^!b", "OpenFolder")
HotKeySet("^!e", "ExitScript")

Func OpenNotepad()
    Run("notepad.exe")
EndFunc

Func OpenFolder()
    Run("explorer.exe C:\")
EndFunc

Func ExitScript()
    Exit
EndFunc

; Keep script running
While 1
    Sleep(100)
WEnd

