; 17. Random Password Generator
; Question: Develop a script that generates a random password of a specified length containing letters, numbers, and special characters, then displays it in a message box.
; Adnan Khan/AB
#include <GUIConstantsEx.au3>

$hGUI = GUICreate("Password Generator", 400, 200)
$inputLength = GUICtrlCreateInput("12", 80, 30, 100, 20)
GUICtrlCreateLabel("Length:", 10, 32, 60, 20)
$chkLetters = GUICtrlCreateCheckbox("Letters", 10, 60, 80, 20)
$chkNumbers = GUICtrlCreateCheckbox("Numbers", 100, 60, 80, 20)
$chkSpecial = GUICtrlCreateCheckbox("Special", 190, 60, 80, 20)
$btnGenerate = GUICtrlCreateButton("Generate", 80, 90, 100, 30)
$editPassword = GUICtrlCreateEdit("", 10, 130, 380, 50)

GUICtrlSetState($chkLetters, $GUI_CHECKED)
GUICtrlSetState($chkNumbers, $GUI_CHECKED)
GUICtrlSetState($chkSpecial, $GUI_CHECKED)

GUISetState(@SW_SHOW)

While 1
    $nMsg = GUIGetMsg()
    Switch $nMsg
        Case $GUI_EVENT_CLOSE
            Exit
        Case $btnGenerate
            $iLength = Int(GUICtrlRead($inputLength))
            $bLetters = GUICtrlRead($chkLetters) = $GUI_CHECKED
            $bNumbers = GUICtrlRead($chkNumbers) = $GUI_CHECKED
            $bSpecial = GUICtrlRead($chkSpecial) = $GUI_CHECKED
            
            $sPassword = GeneratePassword($iLength, $bLetters, $bNumbers, $bSpecial)
            GUICtrlSetData($editPassword, $sPassword)
    EndSwitch
WEnd

Func GeneratePassword($iLength, $bLetters, $bNumbers, $bSpecial)
    Local $sChars = ""
    If $bLetters Then $sChars &= "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ"
    If $bNumbers Then $sChars &= "0123456789"
    If $bSpecial Then $sChars &= "!@#$%^&*()_+-=[]{}|;:,.<>?"
    
    Local $sPassword = ""
    For $i = 1 To $iLength
        $sPassword &= StringMid($sChars, Random(1, StringLen($sChars), 1), 1)
    Next
    
    Return $sPassword
EndFunc
