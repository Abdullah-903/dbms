; 5. Desktop Cleanup Helper
; Question: Write a script to identify and move all .lnk (shortcut) files from the desktop to a folder called "Shortcuts" on the desktop.
; Ishita Shah/AB
$sDesktopPath = @DesktopDir
$sShortcutsFolder = $sDesktopPath & "\Shortcuts"

DirCreate($sShortcutsFolder)

$aFiles = _FileListToArray($sDesktopPath, "*.lnk", 1)
If IsArray($aFiles) Then
    For $i = 1 To $aFiles[0]
        FileMove($sDesktopPath & "\" & $aFiles[$i], $sShortcutsFolder & "\" & $aFiles[$i])
    Next
    MsgBox(0, "Cleanup Complete", $aFiles[0] & " shortcut files moved to Shortcuts folder")
