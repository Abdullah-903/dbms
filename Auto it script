; 15. Temporary File Cleaner
; Question: Write a script that deletes all files in the system's temporary folder and displays a summary of the number of files deleted.
; Shubham Gupta/AB
#include <File.au3>

$sTempFolder = @TempDir
$aFiles = _FileListToArray($sTempFolder, "*.*", 1)

If IsArray($aFiles) Then
    Local $iDeleted = 0
    For $i = 1 To $aFiles[0]
        If FileDelete($sTempFolder & "\" & $aFiles[$i]) Then
            $iDeleted += 1
        EndIf
    Next
    MsgBox(0, "Cleanup Complete", $iDeleted & " temporary files deleted from " & $sTempFolder)
Else
    MsgBox(0, "No Files", "No temporary files found")
EndIf

