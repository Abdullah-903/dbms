; 12. Folder Size Calculator
; Question: Write a script that calculates the total size of a specified folder and displays the result in a message box.
; Soumyajit Gharami/AB
#include <GUIConstantsEx.au3>
#include <File.au3>

$hGUI = GUICreate("Folder Size Calculator", 500, 150)
$btnBrowse = GUICtrlCreateButton("Select Folder", 50, 30, 100, 30)
$lblResult = GUICtrlCreateLabel("Select a folder to calculate its size", 50, 80, 400, 40)
GUISetState(@SW_SHOW)

While 1
    $nMsg = GUIGetMsg()
    Switch $nMsg
        Case $GUI_EVENT_CLOSE
            Exit
        Case $btnBrowse
            $sFolder = FileSelectFolder("Select folder to calculate size", "")
            If Not @error Then
                $iSize = DirGetSize($sFolder)
                $sSizeFormatted = FormatBytes($iSize)
                GUICtrlSetData($lblResult, "Folder: " & $sFolder & @CRLF & "Size: " & $sSizeFormatted)
            EndIf
    EndSwitch
WEnd

Func FormatBytes($iBytes)
    If $iBytes < 1024 Then
        Return $iBytes & " bytes"
    ElseIf $iBytes < 1024 * 1024 Then
        Return Round($iBytes / 1024, 2) & " KB"
    ElseIf $iBytes < 1024 * 1024 * 1024 Then
        Return Round($iBytes / (1024 * 1024), 2) & " MB"
    Else
        Return Round($iBytes / (1024 * 1024 * 1024), 2) & " GB"
    EndIf
EndFunc

