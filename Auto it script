; 7. Basic Countdown Timer
; Question: Create a script with a GUI to set a countdown timer. When the timer reaches zero, it displays a message box or plays a sound.
; Archee Patel/AB
#include <GUIConstantsEx.au3>
#include <StaticConstants.au3>

$hGUI = GUICreate("Countdown Timer", 300, 150)
$inputMinutes = GUICtrlCreateInput("", 50, 30, 100, 20)
GUICtrlCreateLabel("Minutes:", 10, 32, 50, 20)
$btnStart = GUICtrlCreateButton("Start Timer", 50, 60, 100, 30)
$lblCountdown = GUICtrlCreateLabel("", 50, 100, 200, 30, $SS_CENTER)
GUISetState(@SW_SHOW)

While 1
    $nMsg = GUIGetMsg()
    Switch $nMsg
        Case $GUI_EVENT_CLOSE
            Exit
        Case $btnStart
            $iMinutes = Int(GUICtrlRead($inputMinutes))
            If $iMinutes > 0 Then
                StartCountdown($iMinutes)
            EndIf
    EndSwitch
WEnd

Func StartCountdown($iMinutes)
    Local $iSeconds = $iMinutes * 60
    
    While $iSeconds > 0
        Local $iMins = Int($iSeconds / 60)
        Local $iSecs = Mod($iSeconds, 60)
        GUICtrlSetData($lblCountdown, StringFormat("%02d:%02d", $iMins, $iSecs))
        Sleep(1000)
        $iSeconds -= 1
    WEnd
    
    GUICtrlSetData($lblCountdown, "Time's Up!")
    MsgBox(0, "Timer", "Countdown finished!")
    Beep(1000, 1000)
EndFunc

