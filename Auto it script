; 16. Custom Shutdown Timer
; Question: Create a script with an input box where the user can specify the number of minutes after which the system should shut down.
; Kalu Abdullah Sharafat/AB
#include <GUIConstantsEx.au3>

$hGUI = GUICreate("Shutdown Timer", 300, 150)
$inputMinutes = GUICtrlCreateInput("", 80, 30, 100, 20)
GUICtrlCreateLabel("Minutes:", 10, 32, 60, 20)
$btnSet = GUICtrlCreateButton("Set Timer", 80, 60, 100, 30)
$btnCancel = GUICtrlCreateButton("Cancel", 80, 100, 100, 30)
GUISetState(@SW_SHOW)

While 1
    $nMsg = GUIGetMsg()
    Switch $nMsg
        Case $GUI_EVENT_CLOSE
            Exit
        Case $btnSet
            $iMinutes = Int(GUICtrlRead($inputMinutes))
            If $iMinutes > 0 Then
                $iSeconds = $iMinutes * 60
                RunWait(@ComSpec & " /c shutdown /s /t " & $iSeconds, "", @SW_HIDE)
                MsgBox(0, "Timer Set", "System will shutdown in " & $iMinutes & " minutes")
            EndIf
        Case $btnCancel
            RunWait(@ComSpec & " /c shutdown /a", "", @SW_HIDE)
            MsgBox(0, "Cancelled", "Shutdown timer cancelled")
    EndSwitch
WEnd

