; 3. Simple Screenshot Tool
; Question: Write a script that takes a screenshot when a specific hotkey (e.g., PrintScreen) is pressed and saves it to a predefined folder with a timestamp in the filename.
; Krisha Parekh/AB
#include <GUIConstantsEx.au3>
#include <Date.au3>

HotKeySet("{PRINTSCREEN}", "TakeScreenshot")

Func TakeScreenshot()
    $sTimestamp = StringReplace(_NowCalc(), "/", "-")
    $sTimestamp = StringReplace($sTimestamp, ":", "-")
    $sTimestamp = StringReplace($sTimestamp, " ", "_")
    
    $sFolder = @DesktopDir & "\Screenshots"
    DirCreate($sFolder)
    
    $sFilePath = $sFolder & "\Screenshot_" & $sTimestamp & ".png"
    
    ; Take screenshot using built-in function
    _ScreenCapture_Capture($sFilePath)
    
    MsgBox(0, "Screenshot", "Screenshot saved to: " & $sFilePath)
EndFunc

#include <ScreenCapture.au3>

; Keep script running
While 1
    Sleep(100)
WEnd

