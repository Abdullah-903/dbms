; 14. Simple Process Checker
; Question: Create a script that checks if a specific process (e.g., notepad.exe) is running. If it is, display a message; otherwise, start the application.
; Arpita Hule/AB
#include <GUIConstantsEx.au3>

$hGUI = GUICreate("Process Checker", 400, 150)
$inputProcess = GUICtrlCreateInput("notepad.exe", 80, 30, 200, 20)
GUICtrlCreateLabel("Process:", 10, 32, 60, 20)
$btnCheck = GUICtrlCreateButton("Check Process", 80, 60, 100, 30)
$btnStart = GUICtrlCreateButton("Start Process", 190, 60, 100, 30)
$lblStatus = GUICtrlCreateLabel("", 80, 100, 300, 30)
GUISetState(@SW_SHOW)

While 1
    $nMsg = GUIGetMsg()
    Switch $nMsg
        Case $GUI_EVENT_CLOSE
            Exit
        Case $btnCheck
            $sProcess = GUICtrlRead($inputProcess)
            If ProcessExists($sProcess) Then
                GUICtrlSetData($lblStatus, $sProcess & " is running")
            Else
                GUICtrlSetData($lblStatus, $sProcess & " is not running")
            EndIf
        Case $btnStart
            $sProcess = GUICtrlRead($inputProcess)
            If Not ProcessExists($sProcess) Then
                Run($sProcess)
                GUICtrlSetData($lblStatus, "Started " & $sProcess)
            Else
                GUICtrlSetData($lblStatus, $sProcess & " is already running")
            EndIf
    EndSwitch
WEnd

